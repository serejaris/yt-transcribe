#!/usr/bin/env bash
# Advanced Video Transcriber with model selection

set -e  # Exit on error

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Get script directory
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
VENV_PATH="$SCRIPT_DIR/venv"
PYTHON_SCRIPT="$SCRIPT_DIR/transcribe.py"

# Default model
MODEL="small"

# Show help
show_help() {
    echo "🎙️  Video Transcriber"
    echo ""
    echo "Usage: transcribe-video [OPTIONS] <video_url> [output_name]"
    echo ""
    echo "Options:"
    echo "  -m, --model <model>   Whisper model to use (default: small)"
    echo "                        Available: tiny, base, small, medium, large"
    echo "  -h, --help           Show this help message"
    echo ""
    echo "Examples:"
    echo "  transcribe-video https://youtube.com/watch?v=..."
    echo "  transcribe-video -m large https://youtube.com/watch?v=..."
    echo "  transcribe-video --model tiny https://youtube.com/watch?v=... my_transcript"
    echo ""
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -m|--model)
            MODEL="$2"
            shift 2
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

# Check if URL provided
if [ $# -eq 0 ]; then
    echo -e "${RED}❌ Error: No video URL provided${NC}"
    echo ""
    show_help
    exit 1
fi

VIDEO_URL="$1"
OUTPUT_NAME="$2"

# Validate model
if [[ ! "$MODEL" =~ ^(tiny|base|small|medium|large)$ ]]; then
    echo -e "${RED}❌ Error: Invalid model '$MODEL'${NC}"
    echo "Available models: tiny, base, small, medium, large"
    exit 1
fi

# Check/create virtual environment
if [ ! -d "$VENV_PATH" ]; then
    echo -e "${YELLOW}📦 First time setup...${NC}"
    echo "Creating virtual environment..."
    python3 -m venv "$VENV_PATH"
    
    echo "Installing dependencies (this may take a few minutes)..."
    "$VENV_PATH/bin/pip" install --upgrade pip --quiet
    "$VENV_PATH/bin/pip" install yt-dlp --quiet
    "$VENV_PATH/bin/pip" install torch --index-url https://download.pytorch.org/whl/cpu --quiet
    "$VENV_PATH/bin/pip" install git+https://github.com/openai/whisper.git --quiet
    "$VENV_PATH/bin/pip" install ffmpeg-python --quiet
    echo -e "${GREEN}✅ Setup complete!${NC}"
    echo ""
fi

# Check ffmpeg
if ! command -v ffmpeg &> /dev/null; then
    echo -e "${RED}❌ ffmpeg is not installed!${NC}"
    echo "Please install it first:"
    echo "  Mac: brew install ffmpeg"
    echo "  Linux: sudo apt install ffmpeg"
    echo "  Windows: Download from https://ffmpeg.org"
    exit 1
fi

# Update model in Python script
sed -i.bak "s/model_size=\"[^\"]*\"/model_size=\"$MODEL\"/g" "$PYTHON_SCRIPT"
rm -f "$PYTHON_SCRIPT.bak"

# Show what we're doing
echo -e "${BLUE}🎬 Transcribing video...${NC}"
echo -e "URL: $VIDEO_URL"
echo -e "Model: ${GREEN}$MODEL${NC}"
if [ -n "$OUTPUT_NAME" ]; then
    echo -e "Output: $OUTPUT_NAME.txt"
fi
echo ""

# Run transcription
if [ -n "$OUTPUT_NAME" ]; then
    "$VENV_PATH/bin/python" "$PYTHON_SCRIPT" "$VIDEO_URL" "$OUTPUT_NAME"
else
    "$VENV_PATH/bin/python" "$PYTHON_SCRIPT" "$VIDEO_URL"
fi